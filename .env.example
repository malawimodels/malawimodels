VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

VITE_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET_PROFILE=your-unsigned-profile-preset
VITE_CLOUDINARY_UPLOAD_PRESET_GALLERY=your-unsigned-gallery-preset
VITE_CLOUDINARY_UPLOAD_PRESET_PAYMENT=your-unsigned-payment-preset
VITE_CLOUDINARY_UPLOAD_PRESET_VOICE=your-unsigned-voice-preset

# Vite dev does not serve Cloudflare Pages Functions. Leave this unset unless
# you are running a local functions runtime/proxy that serves /api/ably-token.
VITE_ENABLE_ABLY_DEV=false

# Vite dev also does not serve the admin hard-delete Cloudflare Function.
# Leave unset unless /api/admin-delete-user is available locally.
VITE_ENABLE_ADMIN_DELETE_DEV=false

# Server-only Cloudflare Pages Function variables. Never prefix these with VITE_.
SUPABASE_SERVICE_ROLE_KEY=server-only-service-role-key
ABLY_ROOT_API_KEY=server-only-ably-root-key